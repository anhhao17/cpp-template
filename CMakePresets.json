{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "native",
      "displayName": "Native (host) build",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/host.cmake",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "native-asan",
      "displayName": "Native build with AddressSanitizer",
      "inherits": "native",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "aarch64",
      "displayName": "Cross build for aarch64-linux-gnu",
      "inherits": "base",
      "toolchainFile": "${sourceDir}/cmake/toolchains/aarch64-linux-gnu.cmake",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    },
    {
      "name": "native-asio",
      "displayName": "Native build, Boost.Asio transport",
      "inherits": "native",
      "cacheVariables": { "ETLX_TRANSPORT": "asio" }
    },
    {
      "name": "aarch64-asio",
      "displayName": "Cross aarch64 build, Boost.Asio transport",
      "inherits": "aarch64",
      "cacheVariables": { "ETLX_TRANSPORT": "asio" }
    }
  ],
  "buildPresets": [
    { "name": "native",       "configurePreset": "native" },
    { "name": "native-asan",  "configurePreset": "native-asan" },
    { "name": "native-asio",  "configurePreset": "native-asio" },
    { "name": "aarch64",      "configurePreset": "aarch64" },
    { "name": "aarch64-asio", "configurePreset": "aarch64-asio" }
  ],
  "testPresets": [
    {
      "name": "native",
      "configurePreset": "native",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "native-asio",
      "configurePreset": "native-asio",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "aarch64",
      "configurePreset": "aarch64",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "aarch64-asio",
      "configurePreset": "aarch64-asio",
      "output": { "outputOnFailure": true }
    }
  ]
}
